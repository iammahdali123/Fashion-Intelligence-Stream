    <Node ToolID="30">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
        <Position x="546" y="486" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <FormulaFields>
            <FormulaField expression="// 1. PROMOTIONS (Highest Priority - Drives immediate sales spikes)&#xA;IF Contains(Uppercase([Post_Text]), &quot;SALE&quot;) OR Contains(Uppercase([Post_Text]), &quot;% OFF&quot;) OR Contains(Uppercase([Post_Text]), &quot;REDUCTION&quot;) OR Contains(Uppercase([Post_Text]), &quot;CLEARANCE&quot;) &#xA;THEN &quot;Promotional Sale&quot;&#xA;&#xA;// 2. MAJOR EVENTS (Drives seasonal wardrobe overhauls)&#xA;ELSEIF Contains(Uppercase([Post_Text]), &quot;EID&quot;) &#xA;THEN &quot;Eid Collection&quot;&#xA;&#xA;ELSEIF Contains(Uppercase([Post_Text]), &quot;RAMADAN&quot;) OR Contains(Uppercase([Post_Text]), &quot;RAMAZAN&quot;) &#xA;THEN &quot;Ramadan Edit&quot;&#xA;&#xA;// 3. SEASONS / FABRICS (The core catalog drivers)&#xA;ELSEIF Contains(Uppercase([Post_Text]), &quot;SUMMER&quot;) OR Contains(Uppercase([Post_Text]), &quot;LAWN&quot;) &#xA;THEN &quot;Summer Lawn&quot;&#xA;&#xA;ELSEIF Contains(Uppercase([Post_Text]), &quot;SPRING&quot;) &#xA;THEN &quot;Spring Collection&quot;&#xA;&#xA;ELSEIF Contains(Uppercase([Post_Text]), &quot;WINTER&quot;) OR Contains(Uppercase([Post_Text]), &quot;KHADDAR&quot;) OR Contains(Uppercase([Post_Text]), &quot;VELVET&quot;) OR Contains(Uppercase([Post_Text]), &quot;LINEN&quot;)&#xA;THEN &quot;Winter Collection&quot;&#xA;&#xA;// 4. FORMATS (Evergreen products pushed when no major season/event is active)&#xA;ELSEIF Contains(Uppercase([Post_Text]), &quot;PRET&quot;) OR Contains(Uppercase([Post_Text]), &quot;READY TO WEAR&quot;) OR Contains(Uppercase([Post_Text]), &quot;FUSION&quot;)&#xA;THEN &quot;Ready to Wear / Pret&quot;&#xA;&#xA;ELSEIF Contains(Uppercase([Post_Text]), &quot;UNSTITCHED&quot;) &#xA;THEN &quot;Unstitched Collection&quot;&#xA;&#xA;// 5. DEFAULT CATCH-ALL (Prevents NULL values in your Power BI Dashboard)&#xA;ELSE &quot;Core Collection / Brand Campaign&quot;&#xA;ENDIF" field="Campaign_Category" size="2147483647" type="V_String" enabled="true" />
          </FormulaFields>
        </Configuration>
        <Annotation DisplayMode="0">
